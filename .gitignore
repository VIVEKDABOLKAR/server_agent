# genrate gitignore file for current directory go project
# =========================
# Go build files
# =========================
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.coverprofile

# Build directories
bin/
dist/
build/

# =========================
# Go modules
# =========================
vendor/

# =========================
# IDE / Editor files
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# OS specific files
# =========================
.DS_Store
Thumbs.db

# =========================
# Environment / Secrets
# =========================
.env
.env.*
config.yaml
config.json

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# Temporary files
# =========================
tmp/
temp/